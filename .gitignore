# .scitex/ is runtime state for local tooling, but the audit-whitelist
# config under .scitex/dev/config.yaml needs to ship so CI sees the same
# whitelist as local. Switch to file-level exclusion + negation.
.scitex/*
!.scitex/dev/
.scitex/dev/*
!.scitex/dev/config.yaml
.worktrees/
